{
  "name": "rojo-project-template",
  "emitLegacyScripts": false,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/shared",
      "$ignoreUnknownInstances": true,
      "Client": {
        "$path": "src/client"
      }
    },
    "ServerScriptService": {
      "$path": "src/server"
    }
  }
}